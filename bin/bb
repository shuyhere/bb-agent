#!/usr/bin/env node

"use strict";

const { execFileSync } = require("child_process");
const path = require("path");
const fs = require("fs");
const os = require("os");

function getBinaryPath() {
  const platform = os.platform();
  const arch = os.arch();

  const platformMap = {
    darwin: "apple-darwin",
    linux: "unknown-linux-gnu",
  };
  const archMap = {
    x64: "x86_64",
    arm64: "aarch64",
  };

  const target = `${archMap[arch]}-${platformMap[platform]}`;
  if (!target || target.includes("undefined")) {
    console.error(`Unsupported platform: ${platform}-${arch}`);
    process.exit(1);
  }

  // Check for binary in the package directory
  const binDir = path.join(__dirname, "..", "native");
  const binName = platform === "win32" ? "bb.exe" : "bb";
  const binPath = path.join(binDir, binName);

  if (fs.existsSync(binPath)) {
    return binPath;
  }

  // Check if bb is available in PATH (cargo install)
  const pathBin = findInPath("bb");
  if (pathBin) {
    return pathBin;
  }

  console.error(
    "BB-Agent binary not found.\n\n" +
    "The postinstall script may have failed. Try:\n" +
    "  1. Install Rust: curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh\n" +
    "  2. Build manually: cargo install --path crates/cli\n" +
    "  3. Then run: bb\n"
  );
  process.exit(1);
}

function findInPath(name) {
  const envPath = process.env.PATH || "";
  const dirs = envPath.split(path.delimiter);
  for (const dir of dirs) {
    const full = path.join(dir, name);
    try {
      fs.accessSync(full, fs.constants.X_OK);
      return full;
    } catch {
      // not found in this dir
    }
  }
  return null;
}

const binary = getBinaryPath();
const args = process.argv.slice(2);

try {
  execFileSync(binary, args, { stdio: "inherit" });
} catch (err) {
  if (err.status !== null) {
    process.exit(err.status);
  }
  process.exit(1);
}
